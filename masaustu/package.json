{
  "name": "satinalma-rapor",
  "version": "1.0.30",
  "description": "Satın Alma Rapor Uygulaması",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run webpack\" \"wait-on dist/bundle.js && electron .\"",
    "webpack": "webpack --mode development --watch",
    "build:win": "webpack --mode production && electron-builder --win && node scripts/embed-icon-exe.js",
    "build:mac": "webpack --mode production && electron-builder --mac",
    "publish:win": "webpack --mode production && electron-builder --win --publish always && node scripts/embed-icon-exe.js",
    "publish:mac": "webpack --mode production && electron-builder --mac --publish always",
    "build:win-unpacked": "webpack --mode production && electron-builder --win --dir --publish never -c.compression=store",
    "build:win-unpacked:quick": "electron-builder --win --dir --publish never -c.compression=store",
    "electron": "electron .",
    "api": "node api/server.js",
    "generate-icns": "node scripts/generate-icns.js"
  },
  "build": {
    "appId": "com.satinalma.rapor",
    "productName": "Satin Alma Rapor",
    "directories": {
      "output": "release"
    },
    "forceCodeSigning": false,
    "artifactName": "Satin.Alma.Rapor.Setup.${version}.${ext}",
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "extraFiles": [
        {
          "from": "assets/uninstallerIcon.ico",
          "to": "uninstallerIcon.ico"
        }
      ],
      "publish": [
        {
          "provider": "github",
          "owner": "aytugtugan",
          "repo": "SatinalmaWin",
          "releaseType": "release"
        }
      ]
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "zip",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "publish": [
        {
          "provider": "github",
          "owner": "aytugtugan",
          "repo": "SatinalmaMacOS",
          "releaseType": "release"
        }
      ]
    },
    "dmg": {
      "title": "Satin Alma Rapor ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "Satin Alma Rapor",
      "installerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "runAfterFinish": true,
      "include": "installer.nsh"
    },
    "extraResources": [
      {
        "from": "ocak_2026_data.json",
        "to": "ocak_2026_data.json"
      }
    ],
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "database.js",
      "assets/**/*",
      "ocak_verileri_fixed.json",
      "export_toplam_try.csv"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.24.8",
    "cors": "^2.8.6",
    "dayjs": "^1.11.13",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.8.3",
    "express": "^4.22.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "mssql": "^11.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "dmg-license": "^1.0.11",
    "electron": "^36.3.0",
    "electron-builder": "^26.4.0",
    "html-webpack-plugin": "^5.6.3",
    "jimp": "^0.16.1",
    "style-loader": "^4.0.0",
    "to-ico": "^1.0.0",
    "wait-on": "^8.0.5",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  }
}
