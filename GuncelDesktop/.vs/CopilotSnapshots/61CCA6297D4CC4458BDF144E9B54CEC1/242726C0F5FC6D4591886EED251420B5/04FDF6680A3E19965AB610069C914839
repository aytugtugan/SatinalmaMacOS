const fs = require('fs');

const content = `const sql = require('mssql');

const config = {
  server: '10.35.20.15\\\\SQLSRV',
  database: 'SNCG',
  user: 'ozgur.copkur',
  password: 'Oz2025!!',
  options: {
    encrypt: false,
    trustServerCertificate: true,
    enableArithAbort: true,
  },
  pool: {
    max: 10,
    min: 0,
    idleTimeoutMillis: 30000,
  },
};

let pool = null;
let columnCache = null;

async function getConnection() {
  if (!pool) {
    pool = await sql.connect(config);
  }
  return pool;
}

async function getColumnNames() {
  if (columnCache) return columnCache;
  const conn = await getConnection();
  const result = await conn.request().query(
    "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'YLZ_TALEP_SIPARIS' ORDER BY ORDINAL_POSITION"
  );
  const cols = result.recordset.map(r => r.COLUMN_NAME);
  columnCache = {
    TALEP_NO: cols.find(c => c.includes('TALEP') && c.includes('NUMA')),
    SIPARIS_NO: cols.find(c => c.includes('PAR') && c.includes('NUMA')),
    TESLIM_TARIHI: cols.find(c => c.includes('TESL') && c.includes('TAR')),
    TESLIM_EVRAK_NO: cols.find(c => c.includes('TESL') && c.includes('EVRAK')),
    CARI_UNVANI: cols.find(c => c.includes('CAR')),
    TOPLAM: cols.find(c => c === 'TOPLAM'),
    SIPARIS_TARIHI: cols.find(c => c.includes('PAR') && c.includes('TAR') && !c.includes('ONAY')),
    TALEP_EDEN: cols.find(c => c.includes('TALEP') && c.includes('EDEN')),
    MASRAF_MERKEZI: cols.find(c => c.includes('MASRAF')),
    PARA_BIRIMI: cols.find(c => c.includes('PARA')),
    TUR: cols.find(c => c.length <= 4 && !c.includes('NO')),
    TALEP_TARIHI: cols.find(c => c.includes('TALEP') && c.includes('TAR') && !c.includes('ONAY')),
    ISYERI: cols.find(c => c.includes('YER')),
    SIPARIS_ONAYLAYAN: cols.find(c => c.includes('PAR') && c.includes('ONAY') && !c.includes('TAR')),
    ODEME_VADESI: cols.find(c => c.includes('VADE')),
    BIRIM_FIYAT: cols.find(c => c.includes('B') && c.includes('F') && c.includes('YAT'))
  };
  console.log('Column mapping:', columnCache);
  return columnCache;
}

async function executeQuery(query) {
  const conn = await getConnection();
  const result = await conn.request().query(query);
  return result.recordset;
}

async function getAllData() {
  return await executeQuery('SELECT * FROM YLZ_TALEP_SIPARIS');
}

// Isyeri listesini getir
async function getIsyeriList() {
  const C = await getColumnNames();
  const q = (col) => '[' + col + ']';
  const query = "SELECT DISTINCT " + q(C.ISYERI) + " as isyeri FROM YLZ_TALEP_SIPARIS WHERE " + q(C.ISYERI) + " IS NOT NULL AND " + q(C.ISYERI) + " != '' ORDER BY " + q(C.ISYERI);
  return await executeQuery(query);
}

// Isyeri filtresine gore istatistikler
async function getDashboardStats(isyeriFilter) {
  const conn = await getConnection();
  const C = await getColumnNames();
  const q = (col) => '[' + col + ']';
  
  // Isyeri filtresi
  const whereClause = isyeriFilter && isyeriFilter !== 'all' 
    ? " WHERE " + q(C.ISYERI) + " = '" + isyeriFilter.replace(/'/g, "''") + "'" 
    : "";
  const andClause = isyeriFilter && isyeriFilter !== 'all' 
    ? " AND " + q(C.ISYERI) + " = '" + isyeriFilter.replace(/'/g, "''") + "'" 
    : "";

  // Summary - Tekil siparis sayisi ve toplam tutar
  const summaryQuery = "SELECT COUNT(DISTINCT " + q(C.TALEP_NO) + ") as totalTalep, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as totalSiparis, COUNT(DISTINCT CASE WHEN " + q(C.TESLIM_EVRAK_NO) + " IS NOT NULL AND " + q(C.TESLIM_EVRAK_NO) + " != '' THEN " + q(C.SIPARIS_NO) + " END) as totalTeslimat, COUNT(DISTINCT CASE WHEN " + q(C.TESLIM_EVRAK_NO) + " IS NULL OR " + q(C.TESLIM_EVRAK_NO) + " = '' THEN " + q(C.SIPARIS_NO) + " END) as bekleyenTeslimat, COUNT(DISTINCT " + q(C.CARI_UNVANI) + ") as totalTedarikci, COUNT(DISTINCT " + q(C.TALEP_EDEN) + ") as totalTalepEden FROM YLZ_TALEP_SIPARIS" + whereClause;

  // Siparis bazli tutar - Tekrar eden siparisler tek olarak
  const siparisTutarQuery = "SELECT " + q(C.SIPARIS_NO) + " as siparisNo, MAX(" + q(C.CARI_UNVANI) + ") as tedarikci, SUM(" + q(C.TOPLAM) + ") as toplamTutar FROM YLZ_TALEP_SIPARIS" + whereClause + (whereClause ? " AND " : " WHERE ") + q(C.SIPARIS_NO) + " IS NOT NULL GROUP BY " + q(C.SIPARIS_NO);

  // Toplam siparis tutari
  const toplamTutarQuery = "SELECT ISNULL(SUM(t.toplamTutar), 0) as toplamTutar, ISNULL(AVG(t.toplamTutar), 0) as ortalamaTutar FROM (SELECT " + q(C.SIPARIS_NO) + ", SUM(" + q(C.TOPLAM) + ") as toplamTutar FROM YLZ_TALEP_SIPARIS" + whereClause + (whereClause ? " AND " : " WHERE ") + q(C.SIPARIS_NO) + " IS NOT NULL GROUP BY " + q(C.SIPARIS_NO) + ") t";

  // Aylik trend
  const monthlyTrendQuery = "SELECT FORMAT(" + q(C.SIPARIS_TARIHI) + ", 'yyyy-MM') as ay, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.SIPARIS_TARIHI) + " IS NOT NULL" + andClause + " GROUP BY FORMAT(" + q(C.SIPARIS_TARIHI) + ", 'yyyy-MM') ORDER BY ay DESC";

  // Talep eden
  const talepEdenQuery = "SELECT TOP 10 " + q(C.TALEP_EDEN) + " as talepEden, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, COUNT(*) as talepAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.TALEP_EDEN) + " IS NOT NULL AND " + q(C.TALEP_EDEN) + " != ''" + andClause + " GROUP BY " + q(C.TALEP_EDEN) + " ORDER BY toplamTutar DESC";

  // Masraf merkezi - Siparis tutarinin dagilimi
  const masrafMerkeziQuery = "SELECT TOP 10 " + q(C.MASRAF_MERKEZI) + " as masrafMerkezi, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.MASRAF_MERKEZI) + " IS NOT NULL AND " + q(C.MASRAF_MERKEZI) + " != ''" + andClause + " GROUP BY " + q(C.MASRAF_MERKEZI) + " ORDER BY toplamTutar DESC";

  // Tedarikci
  const tedarikciQuery = "SELECT TOP 10 " + q(C.CARI_UNVANI) + " as tedarikci, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.CARI_UNVANI) + " IS NOT NULL AND " + q(C.CARI_UNVANI) + " != ''" + andClause + " GROUP BY " + q(C.CARI_UNVANI) + " ORDER BY toplamTutar DESC";

  // Para birimi detaylari
  const paraBirimiQuery = "SELECT ISNULL(" + q(C.PARA_BIRIMI) + ", 'TRY') as paraBirimi, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS" + whereClause + " GROUP BY " + q(C.PARA_BIRIMI) + " ORDER BY toplamTutar DESC";

  // Tur
  const turQuery = "SELECT ISNULL(" + q(C.TUR) + ", 'Belirsiz') as tur, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS" + whereClause + " GROUP BY " + q(C.TUR) + " ORDER BY kayitAdedi DESC";

  // Teslim durumu - TESLIM EVRAK NO'ya gore
  const teslimDurumQuery = "SELECT CASE WHEN " + q(C.TESLIM_EVRAK_NO) + " IS NOT NULL AND " + q(C.TESLIM_EVRAK_NO) + " != '' THEN 'Teslim Edildi' ELSE 'Teslim Bekliyor' END as durum, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS" + whereClause + " GROUP BY CASE WHEN " + q(C.TESLIM_EVRAK_NO) + " IS NOT NULL AND " + q(C.TESLIM_EVRAK_NO) + " != '' THEN 'Teslim Edildi' ELSE 'Teslim Bekliyor' END";

  // Isyeri dagilimi
  const isyeriQuery = "SELECT ISNULL(" + q(C.ISYERI) + ", 'Belirsiz') as isyeri, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS GROUP BY " + q(C.ISYERI) + " ORDER BY toplamTutar DESC";

  // Onaylayan
  const onaylayanQuery = "SELECT TOP 10 " + q(C.SIPARIS_ONAYLAYAN) + " as onaylayan, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.SIPARIS_ONAYLAYAN) + " IS NOT NULL AND " + q(C.SIPARIS_ONAYLAYAN) + " != ''" + andClause + " GROUP BY " + q(C.SIPARIS_ONAYLAYAN) + " ORDER BY siparisAdedi DESC";

  // Odeme vadesi detaylari
  const odemeVadesiQuery = "SELECT ISNULL(" + q(C.ODEME_VADESI) + ", 'Belirsiz') as odemeVadesi, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS" + whereClause + " GROUP BY " + q(C.ODEME_VADESI) + " ORDER BY toplamTutar DESC";

  // Teslimat suresi
  const teslimatSuresiQuery = "SELECT AVG(DATEDIFF(DAY, " + q(C.SIPARIS_TARIHI) + ", " + q(C.TESLIM_TARIHI) + ")) as ortalamaTeslimatSuresi, MIN(DATEDIFF(DAY, " + q(C.SIPARIS_TARIHI) + ", " + q(C.TESLIM_TARIHI) + ")) as minTeslimatSuresi, MAX(DATEDIFF(DAY, " + q(C.SIPARIS_TARIHI) + ", " + q(C.TESLIM_TARIHI) + ")) as maxTeslimatSuresi FROM YLZ_TALEP_SIPARIS WHERE " + q(C.SIPARIS_TARIHI) + " IS NOT NULL AND " + q(C.TESLIM_TARIHI) + " IS NOT NULL" + andClause;

  const [summary, toplamTutar, monthlyTrend, talepEden, masrafMerkezi, tedarikci, paraBirimi, tur, teslimDurum, isyeri, onaylayan, odemeVadesi, teslimatSuresi] = await Promise.all([
    conn.request().query(summaryQuery),
    conn.request().query(toplamTutarQuery),
    conn.request().query(monthlyTrendQuery),
    conn.request().query(talepEdenQuery),
    conn.request().query(masrafMerkeziQuery),
    conn.request().query(tedarikciQuery),
    conn.request().query(paraBirimiQuery),
    conn.request().query(turQuery),
    conn.request().query(teslimDurumQuery),
    conn.request().query(isyeriQuery),
    conn.request().query(onaylayanQuery),
    conn.request().query(odemeVadesiQuery),
    conn.request().query(teslimatSuresiQuery)
  ]);

  return {
    summary: { ...summary.recordset[0], ...toplamTutar.recordset[0] },
    monthlyTrend: monthlyTrend.recordset,
    talepEden: talepEden.recordset,
    masrafMerkezi: masrafMerkezi.recordset,
    tedarikci: tedarikci.recordset,
    paraBirimi: paraBirimi.recordset,
    tur: tur.recordset,
    durum: teslimDurum.recordset,
    isyeri: isyeri.recordset,
    onaylayan: onaylayan.recordset,
    odemeVadesi: odemeVadesi.recordset,
    teslimatSuresi: teslimatSuresi.recordset[0]
  };
}

module.exports = { executeQuery, getAllData, getDashboardStats, getIsyeriList };
`;

fs.writeFileSync('database.js', content, 'utf8');
