// Kolon isimleri mapping - Türkçe karakterler için
const COLUMNS = {
  FIRMA_NO: '[FİRMA NUMARASI]',
  FIRMA_ADI: '[FİRMA ADI]',
  ISYERI: '[İŞ YERİ]',
  AMBAR: '[AMBAR]',
  TUR: '[TÜR]',
  MALZEME_KODU: '[MALZEME/HİZMET KODU]',
  MASRAF_MERKEZI: '[MASRAF MERKEZİ]',
  TALEP_NO: '[TALEP NUMARASI]',
  TALEP_EDEN: '[TALEP EDEN]',
  TALEP_TARIHI: '[TALEP TARİHİ]',
  TALEP_ONAYLAYAN: '[TALEP ONAYLAYAN]',
  TALEP_ONAY_TARIHI: '[TALEP ONAY TARİHİ]',
  TALEP_ACIKLAMA: '[TALEP AÇIKLAMA]',
  SIPARIS_NO: '[SİPARİŞ NUMARASI]',
  SIPARISI_ACAN: '[SİPARİŞİ AÇAN]',
  SIPARIS_TARIHI: '[SİPARİŞ TARİHİ]',
  SIPARIS_ONAYLAYAN: '[SİPARİŞ ONAYLAYAN]',
  SIPARIS_ONAY_TARIHI: '[SİPARİŞ ONAY TARİHİ]',
  SIPARIS_MALZEME: '[SİPARİŞ MALZEME]',
  TESLIM_EVRAK_NO: '[TESLİM EVRAK NO]',
  TESLIM_TARIHI: '[TESLİM TARİHİ]',
  CARI_UNVANI: '[CARİ ÜNVANI]',
  TESLIM_ALAN: '[TESLİM ALAN]',
  ACIKLAMA: '[AÇIKLAMA]',
  MIKTAR: '[MİKTAR]',
  BIRIM: '[BİRİM]',
  ODEME_VADESI: '[ÖDEME VADESİ]',
  PARA_BIRIMI: '[PARA BİRİMİ]',
  BIRIM_FIYAT: '[BİRİM FİYAT]',
  TOPLAM: '[TOPLAM]',
  FATURAYI_KAYDEDEN: '[FATURAYI KAYDEDEN]',
  FATURA_KAYDETME_TARIHI: '[FATURA KAYDETME TARİHİ]',
  FATURA_TARIHI: '[FATURA TARİHİ]',
  FATURA_NO: '[FATURA NO]'
};

let pool = null;

async function getConnection() {
  if (!pool) {
    pool = await sql.connect(config);
  }
  return pool;
}

async function executeQuery(query) {
  const connection = await getConnection();
  const result = await connection.request().query(query);
  return result.recordset;
}

async function getAllData() {
  const query = `SELECT * FROM YLZ_TALEP_SIPARIS`;
  return await executeQuery(query);
}

async function getDashboardStats() {
  const connection = await getConnection();
  
  // Özet istatistikler
  const summaryQuery = `
    SELECT 
      COUNT(DISTINCT ${COLUMNS.TALEP_NO}) as totalTalep,
      COUNT(DISTINCT ${COLUMNS.SIPARIS_NO}) as totalSiparis,
      COUNT(DISTINCT CASE WHEN ${COLUMNS.TESLIM_TARIHI} IS NOT NULL THEN ${COLUMNS.SIPARIS_NO} END) as totalTeslimat,
      COUNT(DISTINCT ${COLUMNS.CARI_UNVANI}) as totalTedarikci,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar,
      ISNULL(AVG(${COLUMNS.TOPLAM}), 0) as ortalamaTutar
    FROM YLZ_TALEP_SIPARIS
  `;
  
  // Aylık sipariş trendi
  const monthlyTrendQuery = `
    SELECT 
      FORMAT(${COLUMNS.SIPARIS_TARIHI}, 'yyyy-MM') as ay,
      COUNT(DISTINCT ${COLUMNS.SIPARIS_NO}) as siparisAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${COLUMNS.SIPARIS_TARIHI} IS NOT NULL
    GROUP BY FORMAT(${COLUMNS.SIPARIS_TARIHI}, 'yyyy-MM')
    ORDER BY ay DESC
  `;
  
  // Talep eden kişilere göre dağılım
  const talepEdenQuery = `
    SELECT TOP 10
      ${COLUMNS.TALEP_EDEN} as talepEden,
      COUNT(*) as talepAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${COLUMNS.TALEP_EDEN} IS NOT NULL AND ${COLUMNS.TALEP_EDEN} != ''
    GROUP BY ${COLUMNS.TALEP_EDEN}
    ORDER BY talepAdedi DESC
  `;
  
  // Masraf merkezine göre dağılım
  const masrafMerkeziQuery = `
    SELECT TOP 10
      ${COLUMNS.MASRAF_MERKEZI} as masrafMerkezi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${COLUMNS.MASRAF_MERKEZI} IS NOT NULL AND ${COLUMNS.MASRAF_MERKEZI} != ''
    GROUP BY ${COLUMNS.MASRAF_MERKEZI}
    ORDER BY toplamTutar DESC
  `;
  
  // Tedarikçilere göre dağılım
  const tedarikciQuery = `
    SELECT TOP 10
      ${COLUMNS.CARI_UNVANI} as tedarikci,
      COUNT(DISTINCT ${COLUMNS.SIPARIS_NO}) as siparisAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${COLUMNS.CARI_UNVANI} IS NOT NULL AND ${COLUMNS.CARI_UNVANI} != ''
    GROUP BY ${COLUMNS.CARI_UNVANI}
    ORDER BY toplamTutar DESC
  `;
  
  // Para birimine göre dağılım
  const paraBirimiQuery = `
    SELECT 
      ISNULL(${COLUMNS.PARA_BIRIMI}, 'TRY') as paraBirimi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    GROUP BY ${COLUMNS.PARA_BIRIMI}
    ORDER BY toplamTutar DESC
  `;
  
  // Türe göre dağılım (Malzeme/Hizmet)
  const turQuery = `
    SELECT 
      ISNULL(${COLUMNS.TUR}, 'Belirsiz') as tur,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    GROUP BY ${COLUMNS.TUR}
    ORDER BY kayitAdedi DESC
  `;
  
  // Sipariş durumu (Talep, Sipariş, Teslimat)
  const durumQuery = `
    SELECT 
      CASE 
        WHEN ${COLUMNS.TESLIM_TARIHI} IS NOT NULL THEN 'Teslim Edildi'
        WHEN ${COLUMNS.SIPARIS_TARIHI} IS NOT NULL THEN 'Sipariste'
        WHEN ${COLUMNS.TALEP_TARIHI} IS NOT NULL THEN 'Talepte'
        ELSE 'Belirsiz'
      END as durum,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    GROUP BY 
      CASE 
        WHEN ${COLUMNS.TESLIM_TARIHI} IS NOT NULL THEN 'Teslim Edildi'
        WHEN ${COLUMNS.SIPARIS_TARIHI} IS NOT NULL THEN 'Sipariste'
        WHEN ${COLUMNS.TALEP_TARIHI} IS NOT NULL THEN 'Talepte'
        ELSE 'Belirsiz'
      END
  `;
  
  // İş yerine göre dağılım
  const isyeriQuery = `
    SELECT 
      ISNULL(${COLUMNS.ISYERI}, 'Belirsiz') as isyeri,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    GROUP BY ${COLUMNS.ISYERI}
    ORDER BY toplamTutar DESC
  `;
  
  // Sipariş onaylayan kişilere göre
  const onaylayanQuery = `
    SELECT TOP 10
      ${COLUMNS.SIPARIS_ONAYLAYAN} as onaylayan,
      COUNT(DISTINCT ${COLUMNS.SIPARIS_NO}) as siparisAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${COLUMNS.SIPARIS_ONAYLAYAN} IS NOT NULL AND ${COLUMNS.SIPARIS_ONAYLAYAN} != ''
    GROUP BY ${COLUMNS.SIPARIS_ONAYLAYAN}
    ORDER BY siparisAdedi DESC
  `;
  
  // Ödeme vadesine göre dağılım
  const odemeVadesiQuery = `
    SELECT 
      ISNULL(${COLUMNS.ODEME_VADESI}, 'Belirsiz') as odemeVadesi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${COLUMNS.TOPLAM}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    GROUP BY ${COLUMNS.ODEME_VADESI}
    ORDER BY kayitAdedi DESC
  `;

  // Teslimat performansı - ortalama teslimat süresi
  const teslimatSuresiQuery = `
    SELECT 
      AVG(DATEDIFF(DAY, ${COLUMNS.SIPARIS_TARIHI}, ${COLUMNS.TESLIM_TARIHI})) as ortalamaTeslimatSuresi,
      MIN(DATEDIFF(DAY, ${COLUMNS.SIPARIS_TARIHI}, ${COLUMNS.TESLIM_TARIHI})) as minTeslimatSuresi,
      MAX(DATEDIFF(DAY, ${COLUMNS.SIPARIS_TARIHI}, ${COLUMNS.TESLIM_TARIHI})) as maxTeslimatSuresi
    FROM YLZ_TALEP_SIPARIS
    WHERE ${COLUMNS.SIPARIS_TARIHI} IS NOT NULL AND ${COLUMNS.TESLIM_TARIHI} IS NOT NULL
  `;

  const [
    summary,
    monthlyTrend,
    talepEden,
    masrafMerkezi,
    tedarikci,
    paraBirimi,
    tur,
    durum,
    isyeri,
    onaylayan,
    odemeVadesi,
    teslimatSuresi
  ] = await Promise.all([
    connection.request().query(summaryQuery),
    connection.request().query(monthlyTrendQuery),
    connection.request().query(talepEdenQuery),
    connection.request().query(masrafMerkeziQuery),
    connection.request().query(tedarikciQuery),
    connection.request().query(paraBirimiQuery),
    connection.request().query(turQuery),
    connection.request().query(durumQuery),
    connection.request().query(isyeriQuery),
    connection.request().query(onaylayanQuery),
    connection.request().query(odemeVadesiQuery),
    connection.request().query(teslimatSuresiQuery)
  ]);

  return {
    summary: summary.recordset[0],
    monthlyTrend: monthlyTrend.recordset,
    talepEden: talepEden.recordset,
    masrafMerkezi: masrafMerkezi.recordset,
    tedarikci: tedarikci.recordset,
    paraBirimi: paraBirimi.recordset,
    tur: tur.recordset,
    durum: durum.recordset,
    isyeri: isyeri.recordset,
    onaylayan: onaylayan.recordset,
    odemeVadesi: odemeVadesi.recordset,
    teslimatSuresi: teslimatSuresi.recordset[0]
  };
}

module.exports = {
  executeQuery,
  getAllData,
  getDashboardStats,
};
