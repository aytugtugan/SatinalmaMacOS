import React from 'react';
import { SwitchableChart, formatNumber, formatCurrency } from '../components/SwitchableChart';
import {
  TeamOutlined,
  DollarOutlined,
  ShoppingOutlined,
  TrophyOutlined,
} from '@ant-design/icons';

const TedarikciAnaliz = ({ data }) => {
  if (!data) return null;

  const { tedarikci, summary } = data;

  // Tedarikçilere göre tutar
  const tedarikciTutarData = (tedarikci || []).map(item => ({
    name: item.tedarikci?.substring(0, 25) || 'Belirsiz',
    value: item.toplamTutar,
  }));

  // Tedarikçilere göre sipariş adedi
  const tedarikciAdetData = (tedarikci || []).map(item => ({
    name: item.tedarikci?.substring(0, 25) || 'Belirsiz',
    value: item.siparisAdedi,
  }));

  // En büyük tedarikçi
  const topTedarikci = tedarikci && tedarikci.length > 0 ? tedarikci[0] : null;

  // Toplam tedarikçi tutarı
  const toplamTedarikciTutar = (tedarikci || []).reduce((sum, item) => sum + (item.toplamTutar || 0), 0);

  return (
    <div>
      <div className="page-header">
        <h2>👥 Tedarikçi Analizi</h2>
        <p>Tedarikçi performanslarının detaylı analizi</p>
      </div>

      {/* KPI Cards */}
      <div className="kpi-grid">
        <div className="kpi-card">
          <div className="kpi-icon blue">
            <TeamOutlined />
          </div>
          <div className="kpi-value">{formatNumber(summary?.totalTedarikci || 0)}</div>
          <div className="kpi-label">Toplam Tedarikçi</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon green">
            <DollarOutlined />
          </div>
          <div className="kpi-value">{formatCurrency(toplamTedarikciTutar)}</div>
          <div className="kpi-label">Toplam Harcama</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon orange">
            <TrophyOutlined />
          </div>
          <div className="kpi-value" style={{ fontSize: '18px' }}>
            {topTedarikci?.tedarikci?.substring(0, 20) || '-'}
          </div>
          <div className="kpi-label">En Büyük Tedarikçi</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon purple">
            <ShoppingOutlined />
          </div>
          <div className="kpi-value">{formatCurrency(topTedarikci?.toplamTutar || 0)}</div>
          <div className="kpi-label">En Yüksek Harcama</div>
        </div>
      </div>

      {/* Charts */}
      <div className="charts-grid">
        <SwitchableChart
          title="Tedarikçilere Göre Toplam Tutar"
          data={tedarikciTutarData}
          dataKey="value"
          nameKey="name"
          defaultType="horizontal"
          valueFormatter={formatCurrency}
          height={400}
        />

        <SwitchableChart
          title="Tedarikçilere Göre Sipariş Adedi"
          data={tedarikciAdetData}
          dataKey="value"
          nameKey="name"
          defaultType="bar"
          height={400}
        />

        <SwitchableChart
          title="Tedarikçi Tutar Dağılımı"
          data={tedarikciTutarData.slice(0, 6)}
          dataKey="value"
          nameKey="name"
          defaultType="pie"
          valueFormatter={formatCurrency}
          height={400}
        />

        <SwitchableChart
          title="Tedarikçi Performans Karşılaştırması"
          data={tedarikciAdetData.slice(0, 8)}
          dataKey="value"
          nameKey="name"
          defaultType="radar"
          height={400}
        />
      </div>
    </div>
  );
};

export default TedarikciAnaliz;
