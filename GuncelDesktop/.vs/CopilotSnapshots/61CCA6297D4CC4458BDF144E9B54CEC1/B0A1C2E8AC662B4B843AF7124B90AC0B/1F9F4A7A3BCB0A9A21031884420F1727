import React from 'react';
import { SwitchableChart, formatNumber, formatCurrency } from '../components/SwitchableChart';
import {
  FileTextOutlined,
  ShoppingCartOutlined,
  CheckCircleOutlined,
  TeamOutlined,
  DollarOutlined,
  ClockCircleOutlined,
} from '@ant-design/icons';

const Dashboard = ({ data }) => {
  if (!data) return null;

  const { summary, monthlyTrend, tedarikci, durum, tur, isyeri } = data;

  // Aylık trend verilerini son 12 aya düzenle
  const trendData = (monthlyTrend || []).slice(0, 12).reverse().map(item => ({
    name: item.ay,
    'Sipariş Adedi': item.siparisAdedi,
    'Toplam Tutar': item.toplamTutar,
  }));

  // Durum dağılımı
  const durumData = (durum || []).map(item => ({
    name: item.durum,
    value: item.kayitAdedi,
  }));

  // Tür dağılımı
  const turData = (tur || []).map(item => ({
    name: item.tur || 'Belirsiz',
    value: item.kayitAdedi,
  }));

  // Tedarikçi dağılımı (top 5)
  const tedarikciData = (tedarikci || []).slice(0, 5).map(item => ({
    name: item.tedarikci?.substring(0, 20) || 'Belirsiz',
    value: item.toplamTutar,
  }));

  // İşyeri dağılımı
  const isyeriData = (isyeri || []).slice(0, 6).map(item => ({
    name: item.isyeri || 'Belirsiz',
    value: item.toplamTutar,
  }));

  return (
    <div>
      <div className="page-header">
        <h2>📊 Satın Alma Dashboard</h2>
        <p>Satın alma süreçlerinizin genel görünümü</p>
      </div>

      {/* KPI Cards */}
      <div className="kpi-grid">
        <div className="kpi-card">
          <div className="kpi-icon blue">
            <FileTextOutlined />
          </div>
          <div className="kpi-value">{formatNumber(summary?.totalTalep || 0)}</div>
          <div className="kpi-label">Toplam Talep</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon green">
            <ShoppingCartOutlined />
          </div>
          <div className="kpi-value">{formatNumber(summary?.totalSiparis || 0)}</div>
          <div className="kpi-label">Toplam Sipariş</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon orange">
            <CheckCircleOutlined />
          </div>
          <div className="kpi-value">{formatNumber(summary?.totalTeslimat || 0)}</div>
          <div className="kpi-label">Tamamlanan Teslimat</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon purple">
            <TeamOutlined />
          </div>
          <div className="kpi-value">{formatNumber(summary?.totalTedarikci || 0)}</div>
          <div className="kpi-label">Tedarikçi Sayısı</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon blue">
            <DollarOutlined />
          </div>
          <div className="kpi-value">{formatCurrency(summary?.toplamTutar || 0)}</div>
          <div className="kpi-label">Toplam Harcama</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon green">
            <ClockCircleOutlined />
          </div>
          <div className="kpi-value">{data.teslimatSuresi?.ortalamaTeslimatSuresi || 0} Gün</div>
          <div className="kpi-label">Ort. Teslimat Süresi</div>
        </div>
      </div>

      {/* Charts */}
      <div className="charts-grid">
        <SwitchableChart
          title="Aylık Sipariş Trendi"
          data={trendData}
          dataKey="Toplam Tutar"
          nameKey="name"
          defaultType="area"
          valueFormatter={formatCurrency}
          height={320}
        />

        <SwitchableChart
          title="Sipariş Durumu Dağılımı"
          data={durumData}
          dataKey="value"
          nameKey="name"
          defaultType="pie"
          height={320}
        />

        <SwitchableChart
          title="Tür Dağılımı (Malzeme/Hizmet)"
          data={turData}
          dataKey="value"
          nameKey="name"
          defaultType="pie"
          height={320}
        />

        <SwitchableChart
          title="Top 5 Tedarikçi (Tutara Göre)"
          data={tedarikciData}
          dataKey="value"
          nameKey="name"
          defaultType="horizontal"
          valueFormatter={formatCurrency}
          height={320}
        />

        <SwitchableChart
          title="İşyerine Göre Harcama"
          data={isyeriData}
          dataKey="value"
          nameKey="name"
          defaultType="bar"
          valueFormatter={formatCurrency}
          height={320}
        />
      </div>
    </div>
  );
};

export default Dashboard;
