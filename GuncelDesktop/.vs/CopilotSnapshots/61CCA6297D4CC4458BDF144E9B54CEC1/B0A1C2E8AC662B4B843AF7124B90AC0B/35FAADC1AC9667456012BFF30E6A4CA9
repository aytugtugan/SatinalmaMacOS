import React from 'react';
import { SwitchableChart, formatNumber, formatCurrency } from '../components/SwitchableChart';
import {
  UserOutlined,
  BankOutlined,
  RiseOutlined,
} from '@ant-design/icons';

const TalepAnaliz = ({ data }) => {
  if (!data) return null;

  const { talepEden, masrafMerkezi, summary } = data;

  // Talep eden kişilere göre
  const talepEdenData = (talepEden || []).map(item => ({
    name: item.talepEden?.substring(0, 15) || 'Belirsiz',
    'Talep Adedi': item.talepAdedi,
    'Toplam Tutar': item.toplamTutar,
  }));

  // Masraf merkezine göre
  const masrafMerkeziData = (masrafMerkezi || []).map(item => ({
    name: item.masrafMerkezi?.substring(0, 20) || 'Belirsiz',
    'Kayıt Adedi': item.kayitAdedi,
    'Toplam Tutar': item.toplamTutar,
  }));

  // Talep eden adet grafiği için
  const talepEdenAdetData = talepEdenData.map(item => ({
    name: item.name,
    value: item['Talep Adedi'],
  }));

  // Talep eden tutar grafiği için
  const talepEdenTutarData = talepEdenData.map(item => ({
    name: item.name,
    value: item['Toplam Tutar'],
  }));

  // Masraf merkezi adet grafiği için
  const masrafMerkeziAdetData = masrafMerkeziData.map(item => ({
    name: item.name,
    value: item['Kayıt Adedi'],
  }));

  // Masraf merkezi tutar grafiği için
  const masrafMerkeziTutarData = masrafMerkeziData.map(item => ({
    name: item.name,
    value: item['Toplam Tutar'],
  }));

  return (
    <div>
      <div className="page-header">
        <h2>📋 Talep Analizi</h2>
        <p>Talep süreçlerinin detaylı analizi</p>
      </div>

      {/* KPI Cards */}
      <div className="kpi-grid">
        <div className="kpi-card">
          <div className="kpi-icon blue">
            <UserOutlined />
          </div>
          <div className="kpi-value">{talepEden?.length || 0}</div>
          <div className="kpi-label">Talep Eden Kişi Sayısı</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon green">
            <BankOutlined />
          </div>
          <div className="kpi-value">{masrafMerkezi?.length || 0}</div>
          <div className="kpi-label">Masraf Merkezi Sayısı</div>
        </div>

        <div className="kpi-card">
          <div className="kpi-icon orange">
            <RiseOutlined />
          </div>
          <div className="kpi-value">{formatNumber(summary?.totalTalep || 0)}</div>
          <div className="kpi-label">Toplam Talep</div>
        </div>
      </div>

      {/* Charts */}
      <div className="charts-grid">
        <SwitchableChart
          title="Talep Eden Kişilere Göre Talep Adedi"
          data={talepEdenAdetData}
          dataKey="value"
          nameKey="name"
          defaultType="bar"
          height={350}
        />

        <SwitchableChart
          title="Talep Eden Kişilere Göre Tutar"
          data={talepEdenTutarData}
          dataKey="value"
          nameKey="name"
          defaultType="horizontal"
          valueFormatter={formatCurrency}
          height={350}
        />

        <SwitchableChart
          title="Masraf Merkezine Göre Kayıt Adedi"
          data={masrafMerkeziAdetData}
          dataKey="value"
          nameKey="name"
          defaultType="pie"
          height={350}
        />

        <SwitchableChart
          title="Masraf Merkezine Göre Tutar"
          data={masrafMerkeziTutarData}
          dataKey="value"
          nameKey="name"
          defaultType="bar"
          valueFormatter={formatCurrency}
          height={350}
        />
      </div>
    </div>
  );
};

export default TalepAnaliz;
