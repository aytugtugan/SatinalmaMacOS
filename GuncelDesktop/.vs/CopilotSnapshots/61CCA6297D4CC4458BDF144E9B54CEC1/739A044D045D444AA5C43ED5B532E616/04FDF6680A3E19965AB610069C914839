const fs = require('fs');

const content = `const sql = require('mssql');

const config = {
  server: '10.35.20.15\\\\SQLSRV',
  database: 'SNCG',
  user: 'ozgur.copkur',
  password: 'Oz2025!!',
  options: {
    encrypt: false,
    trustServerCertificate: true,
    enableArithAbort: true,
  },
  pool: {
    max: 10,
    min: 0,
    idleTimeoutMillis: 30000,
  },
};

let pool = null;
let columnCache = null;

async function getConnection() {
  if (!pool) {
    pool = await sql.connect(config);
  }
  return pool;
}

async function getColumnNames() {
  if (columnCache) return columnCache;
  const conn = await getConnection();
  const result = await conn.request().query(
    "SELECT COLUMN_NAME FROM INFORMATION_SCHEMA.COLUMNS WHERE TABLE_NAME = 'YLZ_TALEP_SIPARIS' ORDER BY ORDINAL_POSITION"
  );
  const cols = result.recordset.map(r => r.COLUMN_NAME);
  columnCache = {
    TALEP_NO: cols.find(c => c.includes('TALEP') && c.includes('NUMA')),
    SIPARIS_NO: cols.find(c => c.includes('PAR') && c.includes('NUMA')),
    TESLIM_TARIHI: cols.find(c => c.includes('TESL') && c.includes('TAR')),
    CARI_UNVANI: cols.find(c => c.includes('CAR')),
    TOPLAM: cols.find(c => c === 'TOPLAM'),
    SIPARIS_TARIHI: cols.find(c => c.includes('PAR') && c.includes('TAR') && !c.includes('ONAY')),
    TALEP_EDEN: cols.find(c => c.includes('TALEP') && c.includes('EDEN')),
    MASRAF_MERKEZI: cols.find(c => c.includes('MASRAF')),
    PARA_BIRIMI: cols.find(c => c.includes('PARA')),
    TUR: cols.find(c => c.length <= 4 && !c.includes('NO')),
    TALEP_TARIHI: cols.find(c => c.includes('TALEP') && c.includes('TAR') && !c.includes('ONAY')),
    ISYERI: cols.find(c => c.includes('YER')),
    SIPARIS_ONAYLAYAN: cols.find(c => c.includes('PAR') && c.includes('ONAY') && !c.includes('TAR')),
    ODEME_VADESI: cols.find(c => c.includes('VADE'))
  };
  return columnCache;
}

async function executeQuery(query) {
  const conn = await getConnection();
  const result = await conn.request().query(query);
  return result.recordset;
}

async function getAllData() {
  return await executeQuery('SELECT * FROM YLZ_TALEP_SIPARIS');
}

async function getDashboardStats() {
  const conn = await getConnection();
  const C = await getColumnNames();
  const q = (col) => '[' + col + ']';

  const summaryQuery = 'SELECT COUNT(DISTINCT ' + q(C.TALEP_NO) + ') as totalTalep, COUNT(DISTINCT ' + q(C.SIPARIS_NO) + ') as totalSiparis, COUNT(DISTINCT CASE WHEN ' + q(C.TESLIM_TARIHI) + ' IS NOT NULL THEN ' + q(C.SIPARIS_NO) + ' END) as totalTeslimat, COUNT(DISTINCT ' + q(C.CARI_UNVANI) + ') as totalTedarikci, ISNULL(SUM(' + q(C.TOPLAM) + '), 0) as toplamTutar, ISNULL(AVG(' + q(C.TOPLAM) + '), 0) as ortalamaTutar FROM YLZ_TALEP_SIPARIS';

  const monthlyTrendQuery = "SELECT FORMAT(" + q(C.SIPARIS_TARIHI) + ", 'yyyy-MM') as ay, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.SIPARIS_TARIHI) + " IS NOT NULL GROUP BY FORMAT(" + q(C.SIPARIS_TARIHI) + ", 'yyyy-MM') ORDER BY ay DESC";

  const talepEdenQuery = "SELECT TOP 10 " + q(C.TALEP_EDEN) + " as talepEden, COUNT(*) as talepAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.TALEP_EDEN) + " IS NOT NULL AND " + q(C.TALEP_EDEN) + " != '' GROUP BY " + q(C.TALEP_EDEN) + " ORDER BY talepAdedi DESC";

  const masrafMerkeziQuery = "SELECT TOP 10 " + q(C.MASRAF_MERKEZI) + " as masrafMerkezi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.MASRAF_MERKEZI) + " IS NOT NULL AND " + q(C.MASRAF_MERKEZI) + " != '' GROUP BY " + q(C.MASRAF_MERKEZI) + " ORDER BY toplamTutar DESC";

  const tedarikciQuery = "SELECT TOP 10 " + q(C.CARI_UNVANI) + " as tedarikci, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.CARI_UNVANI) + " IS NOT NULL AND " + q(C.CARI_UNVANI) + " != '' GROUP BY " + q(C.CARI_UNVANI) + " ORDER BY toplamTutar DESC";

  const paraBirimiQuery = "SELECT ISNULL(" + q(C.PARA_BIRIMI) + ", 'TRY') as paraBirimi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS GROUP BY " + q(C.PARA_BIRIMI) + " ORDER BY toplamTutar DESC";

  const turQuery = "SELECT ISNULL(" + q(C.TUR) + ", 'Belirsiz') as tur, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS GROUP BY " + q(C.TUR) + " ORDER BY kayitAdedi DESC";

  const durumQuery = "SELECT CASE WHEN " + q(C.TESLIM_TARIHI) + " IS NOT NULL THEN 'Teslim Edildi' WHEN " + q(C.SIPARIS_TARIHI) + " IS NOT NULL THEN 'Sipariste' WHEN " + q(C.TALEP_TARIHI) + " IS NOT NULL THEN 'Talepte' ELSE 'Belirsiz' END as durum, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS GROUP BY CASE WHEN " + q(C.TESLIM_TARIHI) + " IS NOT NULL THEN 'Teslim Edildi' WHEN " + q(C.SIPARIS_TARIHI) + " IS NOT NULL THEN 'Sipariste' WHEN " + q(C.TALEP_TARIHI) + " IS NOT NULL THEN 'Talepte' ELSE 'Belirsiz' END";

  const isyeriQuery = "SELECT ISNULL(" + q(C.ISYERI) + ", 'Belirsiz') as isyeri, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS GROUP BY " + q(C.ISYERI) + " ORDER BY toplamTutar DESC";

  const onaylayanQuery = "SELECT TOP 10 " + q(C.SIPARIS_ONAYLAYAN) + " as onaylayan, COUNT(DISTINCT " + q(C.SIPARIS_NO) + ") as siparisAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS WHERE " + q(C.SIPARIS_ONAYLAYAN) + " IS NOT NULL AND " + q(C.SIPARIS_ONAYLAYAN) + " != '' GROUP BY " + q(C.SIPARIS_ONAYLAYAN) + " ORDER BY siparisAdedi DESC";

  const odemeVadesiQuery = "SELECT ISNULL(" + q(C.ODEME_VADESI) + ", 'Belirsiz') as odemeVadesi, COUNT(*) as kayitAdedi, ISNULL(SUM(" + q(C.TOPLAM) + "), 0) as toplamTutar FROM YLZ_TALEP_SIPARIS GROUP BY " + q(C.ODEME_VADESI) + " ORDER BY kayitAdedi DESC";

  const teslimatSuresiQuery = "SELECT AVG(DATEDIFF(DAY, " + q(C.SIPARIS_TARIHI) + ", " + q(C.TESLIM_TARIHI) + ")) as ortalamaTeslimatSuresi, MIN(DATEDIFF(DAY, " + q(C.SIPARIS_TARIHI) + ", " + q(C.TESLIM_TARIHI) + ")) as minTeslimatSuresi, MAX(DATEDIFF(DAY, " + q(C.SIPARIS_TARIHI) + ", " + q(C.TESLIM_TARIHI) + ")) as maxTeslimatSuresi FROM YLZ_TALEP_SIPARIS WHERE " + q(C.SIPARIS_TARIHI) + " IS NOT NULL AND " + q(C.TESLIM_TARIHI) + " IS NOT NULL";

  const [summary, monthlyTrend, talepEden, masrafMerkezi, tedarikci, paraBirimi, tur, durum, isyeri, onaylayan, odemeVadesi, teslimatSuresi] = await Promise.all([
    conn.request().query(summaryQuery),
    conn.request().query(monthlyTrendQuery),
    conn.request().query(talepEdenQuery),
    conn.request().query(masrafMerkeziQuery),
    conn.request().query(tedarikciQuery),
    conn.request().query(paraBirimiQuery),
    conn.request().query(turQuery),
    conn.request().query(durumQuery),
    conn.request().query(isyeriQuery),
    conn.request().query(onaylayanQuery),
    conn.request().query(odemeVadesiQuery),
    conn.request().query(teslimatSuresiQuery)
  ]);

  return {
    summary: summary.recordset[0],
    monthlyTrend: monthlyTrend.recordset,
    talepEden: talepEden.recordset,
    masrafMerkezi: masrafMerkezi.recordset,
    tedarikci: tedarikci.recordset,
    paraBirimi: paraBirimi.recordset,
    tur: tur.recordset,
    durum: durum.recordset,
    isyeri: isyeri.recordset,
    onaylayan: onaylayan.recordset,
    odemeVadesi: odemeVadesi.recordset,
    teslimatSuresi: teslimatSuresi.recordset[0]
  };
}

module.exports = { executeQuery, getAllData, getDashboardStats };
`;

fs.writeFileSync('database.js', content, 'utf8');
console.log('database.js created successfully');
