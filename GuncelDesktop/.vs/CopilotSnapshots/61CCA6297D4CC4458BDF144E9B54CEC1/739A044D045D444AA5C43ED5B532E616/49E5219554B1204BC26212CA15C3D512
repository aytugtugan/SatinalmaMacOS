const { contextBridge, ipcRenderer } = require('electron');

contextBridge.exposeInMainWorld('api', {
  getData: (query) => ipcRenderer.invoke('get-data', query),
  getAllData: () => ipcRenderer.invoke('get-all-data'),
  getDashboardStats: (isyeriFilter) => ipcRenderer.invoke('get-dashboard-stats', isyeriFilter),
  getIsyeriList: () => ipcRenderer.invoke('get-isyeri-list'),
});
