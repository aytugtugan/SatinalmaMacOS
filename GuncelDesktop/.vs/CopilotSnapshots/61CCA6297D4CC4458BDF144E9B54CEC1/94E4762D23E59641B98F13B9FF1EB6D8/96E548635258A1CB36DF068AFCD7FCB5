// Kolon isimleri mapping - Turkce karakterler icin SABIT
const COLUMNS = {
  FIRMA_NO: 'FİRMA NUMARASI',
  FIRMA_ADI: 'FİRMA ADI',
  ISYERI: 'İŞ YERİ',
  AMBAR: 'AMBAR',
  TUR: 'TÜR',
  MALZEME_KODU: 'MALZEME/HİZMET KODU',
  MASRAF_MERKEZI: 'MASRAF MERKEZİ',
  TALEP_NO: 'TALEP NUMARASI',
  TALEP_EDEN: 'TALEP EDEN',
  TALEP_TARIHI: 'TALEP TARİHİ',
  TALEP_ONAYLAYAN: 'TALEP ONAYLAYAN',
  TALEP_ONAY_TARIHI: 'TALEP ONAY TARİHİ',
  TALEP_ACIKLAMA: 'TALEP AÇIKLAMA',
  SIPARIS_NO: 'SİPARİŞ NUMARASI',
  SIPARISI_ACAN: 'SİPARİŞİ AÇAN',
  SIPARIS_TARIHI: 'SİPARİŞ TARİHİ',
  SIPARIS_ONAYLAYAN: 'SİPARİŞ ONAYLAYAN',
  SIPARIS_ONAY_TARIHI: 'SİPARİŞ ONAY TARİHİ',
  SIPARIS_MALZEME: 'SİPARİŞ MALZEME',
  TESLIM_EVRAK_NO: 'TESLİM EVRAK NO',
  TESLIM_TARIHI: 'TESLİM TARİHİ',
  CARI_UNVANI: 'CARİ ÜNVANI',
  TESLIM_ALAN: 'TESLİM ALAN',
  ACIKLAMA: 'AÇIKLAMA',
  MIKTAR: 'MİKTAR',
  BIRIM: 'BİRİM',
  ODEME_VADESI: 'ÖDEME VADESİ',
  PARA_BIRIMI: 'PARA BİRİMİ',
  BIRIM_FIYAT: 'BİRİM FİYAT',
  TOPLAM: 'TOPLAM',
  FATURAYI_KAYDEDEN: 'FATURAYI KAYDEDEN',
  FATURA_KAYDETME_TARIHI: 'FATURA KAYDETME TARİHİ',
  FATURA_TARIHI: 'FATURA TARİHİ',
  FATURA_NO: 'FATURA NO'
};

// Kolon isimlerini kose parantez ile sarmalama
const q = (col) => '[' + col + ']';

let pool = null;

async function getConnection() {
  if (!pool) {
    pool = await sql.connect(config);
  }
  return pool;
}

async function executeQuery(query) {
  const connection = await getConnection();
  const result = await connection.request().query(query);
  return result.recordset;
}

async function getAllData() {
  const data = await executeQuery('SELECT * FROM YLZ_TALEP_SIPARIS');
  return { data, columns: COLUMNS };
}

async function getIsyeriList() {
  const query = `SELECT DISTINCT ${q(COLUMNS.ISYERI)} as isyeri FROM YLZ_TALEP_SIPARIS WHERE ${q(COLUMNS.ISYERI)} IS NOT NULL AND ${q(COLUMNS.ISYERI)} != '' ORDER BY ${q(COLUMNS.ISYERI)}`;
  return await executeQuery(query);
}

async function getDashboardStats(isyeriFilter) {
  const connection = await getConnection();
  
  // Isyeri filtresi
  const whereClause = isyeriFilter && isyeriFilter !== 'all' 
    ? ` WHERE ${q(COLUMNS.ISYERI)} = N'${isyeriFilter.replace(/'/g, "''")}'` 
    : "";
  const andClause = isyeriFilter && isyeriFilter !== 'all' 
    ? ` AND ${q(COLUMNS.ISYERI)} = N'${isyeriFilter.replace(/'/g, "''")}'` 
    : "";

  // Summary - Tekil siparis sayisi
  const summaryQuery = `
    SELECT 
      COUNT(DISTINCT ${q(COLUMNS.TALEP_NO)}) as totalTalep,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as totalSiparis,
      COUNT(DISTINCT CASE WHEN ${q(COLUMNS.TESLIM_EVRAK_NO)} IS NOT NULL AND ${q(COLUMNS.TESLIM_EVRAK_NO)} != '' THEN ${q(COLUMNS.SIPARIS_NO)} END) as totalTeslimat,
      COUNT(DISTINCT CASE WHEN ${q(COLUMNS.TESLIM_EVRAK_NO)} IS NULL OR ${q(COLUMNS.TESLIM_EVRAK_NO)} = '' THEN ${q(COLUMNS.SIPARIS_NO)} END) as bekleyenTeslimat,
      COUNT(DISTINCT ${q(COLUMNS.CARI_UNVANI)}) as totalTedarikci,
      COUNT(DISTINCT ${q(COLUMNS.TALEP_EDEN)}) as totalTalepEden
    FROM YLZ_TALEP_SIPARIS${whereClause}
  `;

  // Toplam tutar - Tekrar eden siparisler icin gruplu
  const toplamTutarQuery = `
    SELECT 
      ISNULL(SUM(t.toplamTutar), 0) as toplamTutar, 
      ISNULL(AVG(t.toplamTutar), 0) as ortalamaTutar 
    FROM (
      SELECT ${q(COLUMNS.SIPARIS_NO)}, SUM(${q(COLUMNS.TOPLAM)}) as toplamTutar 
      FROM YLZ_TALEP_SIPARIS${whereClause}${whereClause ? ' AND ' : ' WHERE '}${q(COLUMNS.SIPARIS_NO)} IS NOT NULL 
      GROUP BY ${q(COLUMNS.SIPARIS_NO)}
    ) t
  `;

  // Aylik trend
  const monthlyTrendQuery = `
    SELECT 
      FORMAT(${q(COLUMNS.SIPARIS_TARIHI)}, 'yyyy-MM') as ay,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${q(COLUMNS.SIPARIS_TARIHI)} IS NOT NULL${andClause}
    GROUP BY FORMAT(${q(COLUMNS.SIPARIS_TARIHI)}, 'yyyy-MM')
    ORDER BY ay DESC
  `;

  // Talep eden
  const talepEdenQuery = `
    SELECT TOP 10
      ${q(COLUMNS.TALEP_EDEN)} as talepEden,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      COUNT(*) as talepAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${q(COLUMNS.TALEP_EDEN)} IS NOT NULL AND ${q(COLUMNS.TALEP_EDEN)} != ''${andClause}
    GROUP BY ${q(COLUMNS.TALEP_EDEN)}
    ORDER BY toplamTutar DESC
  `;

  // Masraf merkezi
  const masrafMerkeziQuery = `
    SELECT TOP 10
      ${q(COLUMNS.MASRAF_MERKEZI)} as masrafMerkezi,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${q(COLUMNS.MASRAF_MERKEZI)} IS NOT NULL AND ${q(COLUMNS.MASRAF_MERKEZI)} != ''${andClause}
    GROUP BY ${q(COLUMNS.MASRAF_MERKEZI)}
    ORDER BY toplamTutar DESC
  `;

  // Tedarikci
  const tedarikciQuery = `
    SELECT TOP 10
      ${q(COLUMNS.CARI_UNVANI)} as tedarikci,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${q(COLUMNS.CARI_UNVANI)} IS NOT NULL AND ${q(COLUMNS.CARI_UNVANI)} != ''${andClause}
    GROUP BY ${q(COLUMNS.CARI_UNVANI)}
    ORDER BY toplamTutar DESC
  `;

  // Para birimi
  const paraBirimiQuery = `
    SELECT 
      ISNULL(${q(COLUMNS.PARA_BIRIMI)}, 'TRY') as paraBirimi,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS${whereClause}
    GROUP BY ${q(COLUMNS.PARA_BIRIMI)}
    ORDER BY toplamTutar DESC
  `;

  // Tur
  const turQuery = `
    SELECT 
      ISNULL(${q(COLUMNS.TUR)}, 'Belirsiz') as tur,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS${whereClause}
    GROUP BY ${q(COLUMNS.TUR)}
    ORDER BY kayitAdedi DESC
  `;

  // Teslim durumu - TESLIM EVRAK NO'ya gore
  const teslimDurumQuery = `
    SELECT 
      CASE WHEN ${q(COLUMNS.TESLIM_EVRAK_NO)} IS NOT NULL AND ${q(COLUMNS.TESLIM_EVRAK_NO)} != '' THEN 'Teslim Edildi' ELSE 'Teslim Bekliyor' END as durum,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS${whereClause}
    GROUP BY CASE WHEN ${q(COLUMNS.TESLIM_EVRAK_NO)} IS NOT NULL AND ${q(COLUMNS.TESLIM_EVRAK_NO)} != '' THEN 'Teslim Edildi' ELSE 'Teslim Bekliyor' END
  `;

  // Isyeri dagilimi
  const isyeriQuery = `
    SELECT 
      ISNULL(${q(COLUMNS.ISYERI)}, 'Belirsiz') as isyeri,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    GROUP BY ${q(COLUMNS.ISYERI)}
    ORDER BY toplamTutar DESC
  `;

  // Onaylayan
  const onaylayanQuery = `
    SELECT TOP 10
      ${q(COLUMNS.SIPARIS_ONAYLAYAN)} as onaylayan,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS
    WHERE ${q(COLUMNS.SIPARIS_ONAYLAYAN)} IS NOT NULL AND ${q(COLUMNS.SIPARIS_ONAYLAYAN)} != ''${andClause}
    GROUP BY ${q(COLUMNS.SIPARIS_ONAYLAYAN)}
    ORDER BY siparisAdedi DESC
  `;

  // Odeme vadesi
  const odemeVadesiQuery = `
    SELECT 
      ISNULL(${q(COLUMNS.ODEME_VADESI)}, 'Belirsiz') as odemeVadesi,
      COUNT(DISTINCT ${q(COLUMNS.SIPARIS_NO)}) as siparisAdedi,
      COUNT(*) as kayitAdedi,
      ISNULL(SUM(${q(COLUMNS.TOPLAM)}), 0) as toplamTutar
    FROM YLZ_TALEP_SIPARIS${whereClause}
    GROUP BY ${q(COLUMNS.ODEME_VADESI)}
    ORDER BY toplamTutar DESC
  `;

  // Teslimat suresi
  const teslimatSuresiQuery = `
    SELECT 
      AVG(DATEDIFF(DAY, ${q(COLUMNS.SIPARIS_TARIHI)}, ${q(COLUMNS.TESLIM_TARIHI)})) as ortalamaTeslimatSuresi,
      MIN(DATEDIFF(DAY, ${q(COLUMNS.SIPARIS_TARIHI)}, ${q(COLUMNS.TESLIM_TARIHI)})) as minTeslimatSuresi,
      MAX(DATEDIFF(DAY, ${q(COLUMNS.SIPARIS_TARIHI)}, ${q(COLUMNS.TESLIM_TARIHI)})) as maxTeslimatSuresi
    FROM YLZ_TALEP_SIPARIS
    WHERE ${q(COLUMNS.SIPARIS_TARIHI)} IS NOT NULL AND ${q(COLUMNS.TESLIM_TARIHI)} IS NOT NULL${andClause}
  `;

  const [summary, toplamTutar, monthlyTrend, talepEden, masrafMerkezi, tedarikci, paraBirimi, tur, teslimDurum, isyeri, onaylayan, odemeVadesi, teslimatSuresi] = await Promise.all([
    connection.request().query(summaryQuery),
    connection.request().query(toplamTutarQuery),
    connection.request().query(monthlyTrendQuery),
    connection.request().query(talepEdenQuery),
    connection.request().query(masrafMerkeziQuery),
    connection.request().query(tedarikciQuery),
    connection.request().query(paraBirimiQuery),
    connection.request().query(turQuery),
    connection.request().query(teslimDurumQuery),
    connection.request().query(isyeriQuery),
    connection.request().query(onaylayanQuery),
    connection.request().query(odemeVadesiQuery),
    connection.request().query(teslimatSuresiQuery)
  ]);

  return {
    summary: { ...summary.recordset[0], ...toplamTutar.recordset[0] },
    monthlyTrend: monthlyTrend.recordset,
    talepEden: talepEden.recordset,
    masrafMerkezi: masrafMerkezi.recordset,
    tedarikci: tedarikci.recordset,
    paraBirimi: paraBirimi.recordset,
    tur: tur.recordset,
    durum: teslimDurum.recordset,
    isyeri: isyeri.recordset,
    onaylayan: onaylayan.recordset,
    odemeVadesi: odemeVadesi.recordset,
    teslimatSuresi: teslimatSuresi.recordset[0],
    columns: COLUMNS
  };
}

module.exports = { executeQuery, getAllData, getDashboardStats, getIsyeriList, COLUMNS };
