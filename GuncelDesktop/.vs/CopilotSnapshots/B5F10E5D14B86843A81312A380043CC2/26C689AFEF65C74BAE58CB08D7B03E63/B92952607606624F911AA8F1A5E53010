const Jimp = require('jimp');
const pngToIco = require('png-to-ico');
const fs = require('fs');
const path = require('path');

async function makeIco() {
  const src = path.join(__dirname, '..', 'assets', 'logo.jpg');
  const outIco = path.join(__dirname, '..', 'assets', 'app.ico');
  const tmpDir = path.join(__dirname, 'tmp_icon');
  const sizes = [16, 24, 32, 48, 64, 128, 256];

  if (!fs.existsSync(src)) {
    console.error('Source logo not found:', src);
    process.exit(1);
  }

  if (!fs.existsSync(tmpDir)) fs.mkdirSync(tmpDir, { recursive: true });

  try {
    const image = await Jimp.read(src);
    const pngPaths = [];
    for (const s of sizes) {
      const p = path.join(tmpDir, `icon_${s}.png`);
      const cloned = image.clone().cover(s, s);
      await cloned.writeAsync(p);
      pngPaths.push(p);
    }

    const buf = await pngToIco(pngPaths);
    fs.writeFileSync(outIco, buf);
    console.log('ICO created at', outIco);
  } catch (err) {
    console.error('Failed to create ico:', err);
    process.exit(2);
  } finally {
    try {
      if (fs.existsSync(tmpDir)) {
        for (const f of fs.readdirSync(tmpDir)) {
          fs.unlinkSync(path.join(tmpDir, f));
        }
        fs.rmdirSync(tmpDir);
      }
    } catch (e) {
      // ignore
    }
  }
}

makeIco();
