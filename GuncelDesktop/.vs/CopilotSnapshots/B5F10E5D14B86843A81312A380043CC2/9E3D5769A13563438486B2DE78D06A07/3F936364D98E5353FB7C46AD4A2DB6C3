{
  "name": "satinalma-rapor",
  "version": "1.0.0",
  "description": "Satın Alma Rapor Uygulaması",
  "main": "main.js",
  "scripts": {
    "start": "concurrently \"npm run webpack\" \"wait-on dist/bundle.js && electron .\"",
    "webpack": "webpack --mode development --watch",
    "build": "webpack --mode production && electron-builder",
    "electron": "electron ."
  },
  "build": {
    "appId": "com.satinalma.rapor",
    "productName": "Satın Alma Rapor",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "database.js"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ant-design/icons": "^5.6.1",
    "antd": "^5.24.8",
    "dayjs": "^1.11.13",
    "mssql": "^11.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.27.2",
    "@babel/preset-react": "^7.27.1",
    "babel-loader": "^10.0.0",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.2",
    "electron": "^36.3.0",
    "electron-builder": "^26.4.0",
    "html-webpack-plugin": "^5.6.3",
    "style-loader": "^4.0.0",
    "wait-on": "^8.0.3",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  }
}
