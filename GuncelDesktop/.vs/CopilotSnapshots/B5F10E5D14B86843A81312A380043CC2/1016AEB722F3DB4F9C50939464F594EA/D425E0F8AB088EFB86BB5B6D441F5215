import React, { useState, useMemo } from 'react';
import { Table, Input, DatePicker, Button, Space, Tag, Tooltip } from 'antd';
import { SearchOutlined, ReloadOutlined, DownloadOutlined } from '@ant-design/icons';
import dayjs from 'dayjs';

const { RangePicker } = DatePicker;

const DetayliRapor = ({ data, selectedIsyeri, columns }) => {
  const [searchText, setSearchText] = useState('');
  const [dateRange, setDateRange] = useState(null);
  const [pageSize, setPageSize] = useState(20);

  // Kolon isimlerini al (columns prop'undan veya varsayilan)
  const C = columns || {
    SIPARIS_NO: 'SİPARİŞ NUMARASI',
    TALEP_NO: 'TALEP NUMARASI',
    TALEP_EDEN: 'TALEP EDEN',
    SIPARIS_TARIHI: 'SİPARİŞ TARİHİ',
    CARI_UNVANI: 'CARİ ÜNVANI',
    MASRAF_MERKEZI: 'MASRAF MERKEZİ',
    SIPARIS_MALZEME: 'SİPARİŞ MALZEME',
    MIKTAR: 'MİKTAR',
    BIRIM_FIYAT: 'BİRİM FİYAT',
    TOPLAM: 'TOPLAM',
    PARA_BIRIMI: 'PARA BİRİMİ',
    ODEME_VADESI: 'ÖDEME VADESİ',
    TESLIM_EVRAK_NO: 'TESLİM EVRAK NO',
    ISYERI: 'İŞ YERİ'
  };

  // helper to strip brackets
  const unbracket = (s) => (s ? s.replace(/^\[|\]$/g, '') : s);

  // normalize incoming records: ensure keys like SIPARIS_NO, TALEP_NO exist on each record
  const normalizedData = useMemo(() => {
    const src = data || [];
    const keys = Object.keys(C);
    return src.map((rec) => {
      const out = { ...rec };
      for (const k of keys) {
        if (out[k] !== undefined) continue;
        // candidates: columns[k], unbracket(columns[k]), '['+columns[k]+']'
        const colVal = columns && columns[k] ? columns[k] : C[k];
        const candidates = [k, colVal, unbracket(colVal), `[${unbracket(colVal)}]`];
        for (const cand of candidates) {
          if (cand && rec[cand] !== undefined) {
            out[k] = rec[cand];
            break;
          }
        }
      }
      return out;
    });
  }, [data, columns]);

  // Tablo kolonlari - dinamik kolon isimleriy
  const tableColumns = [
    {
      title: 'Siparis No',
      dataIndex: 'SIPARIS_NO',
      key: 'siparisNo',
      width: 130,
      fixed: 'left',
      sorter: (a, b) => (a['SIPARIS_NO'] || '').toString().localeCompare((b['SIPARIS_NO'] || '').toString()),
    },
    {
      title: 'Talep No',
      dataIndex: 'TALEP_NO',
      key: 'talepNo',
      width: 130,
      sorter: (a, b) => (a['TALEP_NO'] || '').toString().localeCompare((b['TALEP_NO'] || '').toString()),
    },
    {
      title: 'Talep Eden',
      dataIndex: 'TALEP_EDEN',
      key: 'talepEden',
      width: 150,
      ellipsis: true,
      render: (text) => text || '-',
    },
    {
      title: 'Siparis Tarihi',
      dataIndex: 'SIPARIS_TARIHI',
      key: 'siparisTarihi',
      width: 110,
      render: (date) => date ? dayjs(date).format('DD.MM.YYYY') : '-',
      sorter: (a, b) => new Date(a['SIPARIS_TARIHI'] || 0) - new Date(b['SIPARIS_TARIHI'] || 0),
    },
    {
      title: 'Tedarikci',
      dataIndex: 'CARI_UNVANI',
      key: 'cariUnvani',
      width: 200,
      ellipsis: { showTitle: false },
      render: (text) => (<Tooltip placement="topLeft" title={text}>{text || '-'}</Tooltip>),
    },
    {
      title: 'Masraf Merkezi',
      dataIndex: 'MASRAF_MERKEZI',
      key: 'masrafMerkezi',
      width: 150,
      ellipsis: true,
      render: (text) => text || '-',
    },
    {
      title: 'Malzeme/Hizmet',
      dataIndex: 'SIPARIS_MALZEME',
      key: 'malzeme',
      width: 200,
      ellipsis: { showTitle: false },
      render: (text) => (<Tooltip placement="topLeft" title={text}>{text || '-'}</Tooltip>),
    },
    {
      title: 'Miktar',
      dataIndex: 'MIKTAR',
      key: 'miktar',
      width: 80,
      align: 'right',
      render: (val) => val != null ? Number(val).toLocaleString('tr-TR') : '-',
    },
    {
      title: 'Birim Fiyat',
      dataIndex: 'BIRIM_FIYAT',
      key: 'birimFiyat',
      width: 110,
      align: 'right',
      render: (val) => val != null ? `${Number(val).toLocaleString('tr-TR', { minimumFractionDigits: 2 })} TL` : '-',
    },
    {
      title: 'Toplam',
      dataIndex: 'TOPLAM',
      key: 'toplam',
      width: 120,
      align: 'right',
      render: (val) => val != null ? `${Number(val).toLocaleString('tr-TR', { minimumFractionDigits: 2 })} TL` : '-',
      sorter: (a, b) => (Number(a['TOPLAM']) || 0) - (Number(b['TOPLAM']) || 0),
    },
    {
      title: 'Para Birimi',
      dataIndex: 'PARA_BIRIMI',
      key: 'paraBirimi',
      width: 90,
      render: (val) => val || 'TRY',
    },
    {
      title: 'Odeme Vadesi',
      dataIndex: 'ODEME_VADESI',
      key: 'odemeVadesi',
      width: 120,
      ellipsis: true,
      render: (text) => text || '-',
    },
    {
      title: 'Teslim Evrak No',
      dataIndex: 'TESLIM_EVRAK_NO',
      key: 'teslimEvrakNo',
      width: 130,
      render: (text) => text || '-',
    },
    {
      title: 'Teslim Durumu',
      key: 'teslimDurumu',
      width: 120,
      fixed: 'right',
      render: (_, record) => {
        const evrakNo = record['TESLIM_EVRAK_NO'];
        if (evrakNo && String(evrakNo).trim() !== '') {
          return <Tag color="green">Teslim Edildi</Tag>;
        }
        return <Tag color="orange">Bekliyor</Tag>;
      },
      filters: [
        { text: 'Teslim Edildi', value: 'teslim' },
        { text: 'Bekliyor', value: 'bekliyor' },
      ],
      onFilter: (value, record) => {
        const evrakNo = record['TESLIM_EVRAK_NO'];
        if (value === 'teslim') return evrakNo && String(evrakNo).trim() !== '';
        return !evrakNo || String(evrakNo).trim() === '';
      },
    },
  ];

  // Filtreleme - isyeri filtresi dahil
  const filteredData = useMemo(() => {
    let result = normalizedData || [];

    // Isyeri filtresi
    if (selectedIsyeri && selectedIsyeri !== 'all' && C.ISYERI) {
      result = result.filter(item => item['ISYERI'] === selectedIsyeri);
    }

    // Metin aramasi
    if (searchText) {
      const search = searchText.toLowerCase();
      result = result.filter(item =>
        (item['TALEP_NO'] || '').toString().toLowerCase().includes(search) ||
        (item['SIPARIS_NO'] || '').toString().toLowerCase().includes(search) ||
        (item['TALEP_EDEN'] || '').toString().toLowerCase().includes(search) ||
        (item['CARI_UNVANI'] || '').toString().toLowerCase().includes(search) ||
        (item['SIPARIS_MALZEME'] || '').toString().toLowerCase().includes(search) ||
        (item['MASRAF_MERKEZI'] || '').toString().toLowerCase().includes(search)
      );
    }

    // Tarih araligi filtresi
    if (dateRange && dateRange[0] && dateRange[1]) {
      const startDate = dateRange[0].startOf('day');
      const endDate = dateRange[1].endOf('day');
      result = result.filter(item => {
        const itemDate = dayjs(item['SIPARIS_TARIHI']);
        return itemDate.isValid() && (itemDate.isAfter(startDate) || itemDate.isSame(startDate)) && (itemDate.isBefore(endDate) || itemDate.isSame(endDate));
      });
    }

    return result;
  }, [normalizedData, searchText, dateRange, selectedIsyeri, C]);

  // Excel export
  const handleExport = () => {
    const headers = ['Siparis No', 'Talep No', 'Talep Eden', 'Siparis Tarihi', 'Tedarikci', 'Masraf Merkezi', 'Miktar', 'Birim Fiyat', 'Toplam', 'Para Birimi', 'Odeme Vadesi', 'Teslim Evrak No'];
    const keys = ['SIPARIS_NO', 'TALEP_NO', 'TALEP_EDEN', 'SIPARIS_TARIHI', 'CARI_UNVANI', 'MASRAF_MERKEZI', 'MIKTAR', 'BIRIM_FIYAT', 'TOPLAM', 'PARA_BIRIMI', 'ODEME_VADESI', 'TESLIM_EVRAK_NO'];
    
    const csvContent = [
      headers.join(';'),
      ...filteredData.map(row =>
        keys.map(key => {
          const value = row[key];
          if (key === 'SIPARIS_TARIHI' && value) {
            return dayjs(value).format('DD.MM.YYYY');
          }
          return value != null ? value : '';
        }).join(';')
      )
    ].join('\n');

    const blob = new Blob(['\ufeff' + csvContent], { type: 'text/csv;charset=utf-8;' });
    const link = document.createElement('a');
    link.href = URL.createObjectURL(blob);
    link.download = `satinalma_rapor_${dayjs().format('YYYYMMDD_HHmmss')}.csv`;
    link.click();
  };

  // Ozet bilgiler - Benzersiz siparis sayisi ve toplam tutar
  const toplamTutar = filteredData.reduce((sum, item) => sum + (Number(item['TOPLAM']) || 0), 0);
  const teslimEdilen = filteredData.filter(item => {
    const evrakNo = item['TESLIM_EVRAK_NO'];
    return evrakNo && String(evrakNo).trim() !== '';
  }).length;
  const bekleyen = filteredData.filter(item => {
    const evrakNo = item['TESLIM_EVRAK_NO'];
    return !evrakNo || String(evrakNo).trim() === '';
  }).length;
  
  // Benzersiz siparis sayisi
  const benzersizSiparisler = new Set(filteredData.map(item => item['SIPARIS_NO']).filter(Boolean));
  const benzersizSiparisSayisi = benzersizSiparisler.size;

  // debug log first record
  console.log('DetayliRapor sample', { sample: normalizedData[0], columns: C, count: normalizedData.length });

  return (
    <div>
      <div className="page-header">
        <h2>Detayli Rapor</h2>
        <p>Tum satin alma kayitlarinin detayli listesi ve filtreleme</p>
      </div>

      {/* Filters */}
      <div className="data-table-container" style={{ margin: '24px 28px 20px' }}>
        <div className="filter-section">
          <Space wrap size="middle">
            <Input
              placeholder="Ara... (Talep No, Siparis No, Tedarikci, Masraf Merkezi)"
              prefix={<SearchOutlined style={{ color: '#8c8f93' }} />}
              value={searchText}
              onChange={(e) => setSearchText(e.target.value)}
              style={{ width: 360 }}
              allowClear
            />
            <RangePicker
              placeholder={["Baslangic", "Bitis"]}
              onChange={setDateRange}
              format="DD.MM.YYYY"
            />
            <Button icon={<ReloadOutlined />} onClick={() => { setSearchText(''); setDateRange(null); }}>
              Sifirla
            </Button>
            <Button type="primary" icon={<DownloadOutlined />} onClick={handleExport}>
              Excel Indir
            </Button>
          </Space>
        </div>

        {/* Summary */}
        <div className="summary-section">
          <span><strong>Toplam Kayit:</strong> {filteredData.length.toLocaleString('tr-TR')}</span>
          <span><strong>Benzersiz Siparis:</strong> <Tag color="blue">{benzersizSiparisSayisi.toLocaleString('tr-TR')}</Tag></span>
          <span><strong>Toplam Tutar:</strong> {toplamTutar.toLocaleString('tr-TR', { minimumFractionDigits: 2 })} TL</span>
          <span><strong>Teslim Edilen:</strong> <Tag color="green">{teslimEdilen}</Tag></span>
          <span><strong>Bekleyen:</strong> <Tag color="orange">{bekleyen}</Tag></span>
        </div>

        {/* Table */}
        <Table
          columns={tableColumns}
          dataSource={filteredData}
          rowKey={(record, index) => `${record['SIPARIS_NO']}_${record['TALEP_NO']}_${index}`}
          scroll={{ x: 1900, y: 450 }}
          pagination={{
            pageSize: pageSize,
            showSizeChanger: true,
            showQuickJumper: true,
            showTotal: (total) => `Toplam ${total} kayit`,
            pageSizeOptions: ['10', '20', '50', '100'],
            onShowSizeChange: (_, size) => setPageSize(size),
          }}
          size="small"
        />
      </div>
    </div>
  );
};

export default DetayliRapor;
