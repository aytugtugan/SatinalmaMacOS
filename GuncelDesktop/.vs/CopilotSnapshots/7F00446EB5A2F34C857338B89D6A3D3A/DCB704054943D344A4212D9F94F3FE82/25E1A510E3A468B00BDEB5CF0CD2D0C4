    SIPARIS_ONAYLAYAN: id(pick(['SİPARİŞ ONAYLAYAN']) || FALLBACKS.SIPARIS_ONAYLAYAN),
    SIPARIS_ONAY_TARIHI: id(pick(['SİPARİŞ ONAY TARİHİ']) || FALLBACKS.SIPARIS_ONAY_TARIHI),
