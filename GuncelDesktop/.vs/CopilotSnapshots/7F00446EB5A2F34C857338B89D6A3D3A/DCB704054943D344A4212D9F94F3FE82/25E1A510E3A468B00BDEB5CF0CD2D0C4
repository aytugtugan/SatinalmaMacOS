    TALEP_TARIHI: id(pick(['TALEP TARİHİ']) || FALLBACKS.TALEP_TARIHI),
    TALEP_ONAYLAYAN: id(pick(['TALEP ONAYLAYAN']) || FALLBACKS.TALEP_ONAYLAYAN),
    TALEP_ONAY_TARIHI: id(pick(['TALEP ONAY TARİHİ']) || FALLBACKS.TALEP_ONAY_TARIHI),
    TALEP_ACIKLAMA: id(pick(['TALEP AÇIKLAMA']) || FALLBACKS.TALEP_ACIKLAMA),
    SIPARIS_NO: id(pick(['SİPARİŞ NUMARASI','SIPARIS NUMARASI']) || FALLBACKS.SIPARIS_NO),
