  // pick actual column if present else use Turkish fallback
  const pick = (candidates) => {
    for (const cand of candidates) {
      const found = cols.find(x => x && x.toUpperCase() === cand.toUpperCase());
      if (found) return found;
    }
    // fallback by key name if exact column missing
    return null;
  };

  columnCache = {
    FIRMA_NO: id(pick(['FİRMA NUMARASI']) || FALLBACKS.FIRMA_NO),
    FIRMA_ADI: id(pick(['FİRMA ADI']) || FALLBACKS.FIRMA_ADI),
    ISYERI: id(pick(['İŞ YERİ','ISYERI']) || FALLBACKS.ISYERI),
    AMBAR: id(pick(['AMBAR']) || FALLBACKS.AMBAR),
    TUR: id(pick(['TÜR','TUR']) || FALLBACKS.TUR),
    MALZEME_KODU: id(pick(['MALZEME/HİZMET KODU']) || FALLBACKS.MALZEME_KODU),
