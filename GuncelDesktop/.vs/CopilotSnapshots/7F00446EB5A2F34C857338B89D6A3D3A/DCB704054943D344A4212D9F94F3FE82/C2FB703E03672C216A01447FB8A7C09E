  const masrafMerkezi = await convertAndFallback(`COALESCE(${q(C.MASRAF_MERKEZI)}, 'Belirsiz')`, 'masrafMerkezi', masrafMerkeziRaw);
  const tedarikci = await convertAndFallback(`COALESCE(${q(C.CARI_UNVANI)}, 'Belirsiz')`, 'tedarikci', tedarikciRaw);
  const ambar = await convertAndFallback(`COALESCE(${q(C.AMBAR)}, 'Belirsiz')`, 'ambar', ambarRaw);
  const isyeri = await convertAndFallback(`COALESCE(${q(C.ISYERI)}, 'Belirsiz')`, 'isyeri', isyeriRaw);
  const onaylayan = await convertAndFallback(`COALESCE(${q(C.SIPARIS_ONAYLAYAN)}, 'Belirsiz')`, 'onaylayan', onaylayanRaw);
  const odemeVadesi = await convertAndFallback(`COALESCE(${q(C.ODEME_VADESI)}, 'Belirsiz')`, 'odemeVadesi', odemeVadesiRaw);
  const teslimDurum = await convertAndFallback(`CASE WHEN ${q(C.TESLIM_EVRAK_NO)} IS NOT NULL AND ${q(C.TESLIM_EVRAK_NO)} != '' THEN 'Teslim Edildi' ELSE 'Teslim Bekliyor' END`, 'durum', teslimDurumRaw);

  // paraBirimiConverted - per-currency converted totals
  let paraBirimiConverted = [];
  try {
    const perCur = await convertGroupedQuery(`${q(C.PARA_BIRIMI)}`, 'paraBirimi', whereClause);
    paraBirimiConverted = perCur.map(p => ({ paraBirimi: p.paraBirimi || 'TRY', toplam: p.toplamTutar, convertedTRY: p.toplamTutar }));
  } catch (e) {
    console.error('paraBirimiConverted error:', e);
    paraBirimiConverted = paraBirimiRaw.recordset;
  }

  return {
    summary: { ...summary.recordset[0], ...toplamTutar.recordset[0], toplamTutarTRY },
    monthlyTrend,
    talepEden,
    masrafMerkezi,
    tedarikci,
    paraBirimi: paraBirimiRaw.recordset,
    paraBirimiConverted,
    tur: turRaw.recordset,
    durum: teslimDurum,
    ambar,
    onaylayan,
    odemeVadesi,
    teslimatSuresi: teslimatSuresi.recordset[0],
    columns: Object.keys(C)
  };
}

module.exports = { executeQuery, getAllData, getDashboardStats, getIsyeriList, getColumnMapping };
