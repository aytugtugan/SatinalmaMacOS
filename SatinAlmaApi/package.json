{
  "name": "satinalma-api",
  "version": "1.0.0",
  "description": "Satın Alma Rapor API - MSSQL veritabanından satın alma verilerini sunan REST API",
  "main": "src/server.js",
  "bin": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build:win": "pkg . --targets node18-win-x64 --output dist/SatinAlmaApi.exe --compress GZip"
  },
  "pkg": {
    "assets": [
      "src/**/*"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "morgan": "^1.10.0",
    "mssql": "^10.0.2",
    "multer": "^2.0.2",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-dist": "^5.31.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
